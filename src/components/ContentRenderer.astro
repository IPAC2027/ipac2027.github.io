---
import type { ContentBlock, CollapsibleContent, NestedListItem } from '../types/content.ts';
import CollapsibleContentComponent from './content/CollapsibleContent.astro';
import ConferenceCalendar from './content/ConferenceCalendar.astro';
import ExhibitorFloorPlan from './ExhibitorFloorPlan.astro';
import katex from 'katex';

export interface Props {
  blocks: ContentBlock[];
  collapsibleGroup?: string; // Optional group name for accordion behavior
}

const { blocks, collapsibleGroup } = Astro.props;

// Helper function to create slug from text
const createSlug = (text: string | string[]): string => {
  const textStr = Array.isArray(text) ? text.join(' ') : text;
  return textStr.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
};

// Helper function to process markdown formatting
const processMarkdown = (content: string): string => {
  let processedContent = content;
  
  // First, handle escaped characters by replacing them with placeholders
  const escapedChars: { [key: string]: string } = {};
  let escapeIndex = 0;
  
  // Replace escaped asterisks, brackets, backticks, etc. with unique placeholders
  processedContent = processedContent.replace(/\\([*_\[\]`\\])/g, (match, char) => {
    const placeholder = `__ESCAPED_${escapeIndex}__`;
    escapedChars[placeholder] = char;
    escapeIndex++;
    return placeholder;
  });
  
  // Process inline LaTeX math $...$
  processedContent = processedContent.replace(/\$([^$]+)\$/g, (match, latex) => {
    try {
      return katex.renderToString(latex, { throwOnError: false, displayMode: false });
    } catch (e) {
      return match; // Return original if rendering fails
    }
  });
  
  // First, process images ![alt](src)
  processedContent = processedContent.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" style="height: 80px; width: auto; margin-bottom: 1rem;" />');
  
  // Then, process hyperlinks [text](url)
  processedContent = processedContent.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-primary-600 hover:text-primary-800 underline" target="_blank" rel="noopener noreferrer">$1</a>');
  
  // Process bold text **text**
  processedContent = processedContent.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
  
  // Process italic text *text*
  processedContent = processedContent.replace(/\*(.*?)\*/g, '<em>$1</em>');
  
  // Process inline code `text`
  processedContent = processedContent.replace(/`(.*?)`/g, '<code>$1</code>');
  
  // Finally, restore escaped characters
  Object.keys(escapedChars).forEach(placeholder => {
    processedContent = processedContent.replace(new RegExp(placeholder, 'g'), escapedChars[placeholder]);
  });
  
  return processedContent;
};

const isNestedListItemArray = (content: unknown): content is NestedListItem[] => {
  return Array.isArray(content) && content.length > 0 && typeof content[0] === 'object' && content[0] !== null && 'text' in content[0];
};

const renderNestedListHtml = (items: NestedListItem[], className = 'content-list-single'): string => {
  const renderItems = (listItems: NestedListItem[]): string => {
    return listItems.map(item => {
      const processedItem = processMarkdown(item.text);
      const childHtml = item.children && item.children.length > 0
        ? `<ul class="content-list-single">${renderItems(item.children)}</ul>`
        : '';
      return `<li>${processedItem}${childHtml}</li>`;
    }).join('');
  };

  return `<ul class="${className}">${renderItems(items)}</ul>`;
};
---
{blocks.map(block => {
  switch (block.type) {
    case 'title':
      return <h2 class="content-title">{block.content}</h2>;
    
    case 'subtitle': {
      const slug = typeof block.content === 'string' ? createSlug(block.content) : '';
      return <h3 id={slug} class="content-subtitle">{block.content}</h3>;
    }
    
    case 'subsubtitle':
      return <h4 class="content-subsubtitle">{block.content}</h4>;
    
    case 'text': {
      const content = Array.isArray(block.content) ? block.content.join(' ') : block.content;
      if (typeof content !== 'string') {
        return null;
      }
      
      const processedContent = processMarkdown(content);
      return <p class="content-text" set:html={processedContent}></p>;
    }
    
    case 'list':
      if (isNestedListItemArray(block.content)) {
        return (
          <div set:html={renderNestedListHtml(block.content, block.multiColumn !== false ? 'content-list' : 'content-list-single')}></div>
        );
      }
      return (
        <ul class={block.multiColumn !== false ? 'content-list' : 'content-list-single'}>
          {Array.isArray(block.content) && block.content.map(item => {
            const processedItem = processMarkdown(item);
            return <li set:html={processedItem}></li>;
          })}
        </ul>
      );
    
    case 'highlight': {
      const content = Array.isArray(block.content) ? block.content.join(' ') : block.content;
      if (typeof content !== 'string') {
        return null;
      }
      
      const processedContent = processMarkdown(content);
      
      return (
        <div class="content-highlight">
          <p class="text-yellow-900 dark:text-yellow-100 font-medium m-0" set:html={processedContent}></p>
        </div>
      );
    }
    
    case 'warning': {
      const content = Array.isArray(block.content) ? block.content.join(' ') : block.content;
      if (typeof content !== 'string') {
        return null;
      }
      
      const processedContent = processMarkdown(content);
      
      return (
        <div class="bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-700 rounded-lg p-6 mb-6 transition-colors duration-300">
          <div class="flex items-start">
            <svg class="w-5 h-5 text-amber-600 dark:text-amber-400 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
            </svg>
            <p class="text-amber-800 dark:text-amber-100 font-medium m-0" set:html={processedContent}></p>
          </div>
        </div>
      );
    }
    
    case 'success': {
      const content = Array.isArray(block.content) ? block.content.join(' ') : block.content;
      if (typeof content !== 'string') {
        return null;
      }
      
      const processedContent = processMarkdown(content);
      
      return (
        <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-700 rounded-lg p-6 mb-6 transition-colors duration-300">
          <div class="flex items-start">
            <svg class="w-5 h-5 text-green-600 dark:text-green-400 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-green-800 dark:text-green-100 font-medium m-0" set:html={processedContent}></p>
          </div>
        </div>
      );
    }
    
    case 'info': {
      const content = Array.isArray(block.content) ? block.content.join(' ') : block.content;
      if (typeof content !== 'string') {
        return null;
      }
      
      const processedContent = processMarkdown(content);
      
      return (
        <div class="bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-700 rounded-lg p-6 mb-6 transition-colors duration-300">
          <div class="flex items-start">
            <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <p class="text-blue-800 dark:text-blue-100 font-medium m-0" set:html={processedContent}></p>
          </div>
        </div>
      );
    }
    
    case 'card': {
      const content = Array.isArray(block.content) ? block.content.join(' ') : block.content;
      if (typeof content !== 'string') {
        return null;
      }
      
      const processedContent = processMarkdown(content);
      
      return (
        <div class="content-card">
          <p class="text-primary-900 dark:text-primary-100 m-0" set:html={processedContent}></p>
        </div>
      );
    }
    
    case 'grid':
      if (typeof block.content === 'object' && 'columns' in block.content) {
        const columns = Number(block.content.columns);
        
        // Check if any card has custom width
        const hasCustomWidth = block.content.items.some(item => item.width);
        
        // Use flexbox for custom widths, CSS grid for equal columns
        const gridClass = hasCustomWidth ? 'flex flex-wrap gap-6 mb-8' :
                          columns === 3 ? 'content-grid-3' : 
                          columns === 1 ? 'content-grid-1' : 'content-grid';
        
        // Parse markdown content in card items
        const parseCardMarkdown = (content: string) => {
          const lines = content.split('\n').map(line => line.trim()).filter(line => line);
          const elements = [];
          
          let i = 0;
          while (i < lines.length) {
            const line = lines[i];
            
            // Check if this is a list item
            if (line.startsWith('* ') || line.startsWith('- ')) {
              // Collect all consecutive list items
              const listItems = [];
              while (i < lines.length && (lines[i].startsWith('* ') || lines[i].startsWith('- '))) {
                const itemContent = lines[i].substring(2).trim();
                const processedItem = processMarkdown(itemContent);
                listItems.push(processedItem);
                i++;
              }
              
              // Create a list element
              elements.push(
                <ul class="list-disc list-inside space-y-1 text-sm">
                  {listItems.map(item => (
                    <li set:html={item}></li>
                  ))}
                </ul>
              );
            } else {
              // Regular text line - parse images, bold text and line breaks
              let processedLine = line;
              
              // Check if this line contains HTML content (like iframes or calendar)
              if (processedLine.includes('<iframe') || processedLine.includes('<div class="embed') || processedLine.includes('<calendar>')) {
                // Handle special calendar component
                if (processedLine.includes('<calendar>')) {
                  elements.push(<ConferenceCalendar />);
                  i++;
                  continue;
                }
                // Handle HTML embeds directly without markdown processing
                elements.push(<div class="mb-1" set:html={processedLine}></div>);
                i++;
                continue;
              }
              
              // Process markdown formatting
              processedLine = processMarkdown(processedLine);
              
              elements.push(<p class="mb-1 text-sm" set:html={processedLine}></p>);
              i++;
            }
          }
          
          return elements;
        };
        
        return (
          <div class={gridClass}>
            {block.content.items.map(item => {
              // Process LaTeX in title
              const processedTitle = processMarkdown(item.title);
              
              // Build style for custom width using flex-basis, accounting for gap
              const widthStyle = item.width ? `flex: 0 0 calc(${item.width === '1/3' ? '33.333%' : item.width === '2/3' ? '66.667%' : item.width === '1/2' ? '50%' : item.width === '1/4' ? '25%' : item.width === '3/4' ? '75%' : item.width === 'full' ? '100%' : item.width} - 12px); max-width: calc(${item.width === '1/3' ? '33.333%' : item.width === '2/3' ? '66.667%' : item.width === '1/2' ? '50%' : item.width === '1/4' ? '25%' : item.width === '3/4' ? '75%' : item.width === 'full' ? '100%' : item.width} - 12px);` : '';
              
              return (
                <div class={`${block.content.borderless ? '' : 'bg-white dark:bg-primary-800 rounded-lg p-6 shadow-sm border'} ${block.content.borderless ? 'px-2' : ''}`} style={widthStyle}>
                  <div class="flex items-center mb-3">
                    {item.icon && (
                      <div class={item.styledIcon ? "card-icon" : "text-2xl mr-3"}>{item.icon}</div>
                    )}
                    <h4 class="font-semibold text-primary-900 dark:text-primary-100 m-0" set:html={processedTitle}></h4>
                  </div>
                  <div class="text-primary-600 dark:text-primary-300 text-sm">
                    {parseCardMarkdown(item.content)}
                  </div>
                </div>
              );
            })}
          </div>
        );
      }
      return null;
    
    case 'button':
      return (
        <div class="my-8 flex justify-center">
          <a
            href={block.url || '#'}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 bg-accent-600 hover:bg-accent-700 active:bg-accent-800 text-white text-lg font-bold px-10 py-5 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-[1.03]"
          >
            <span>{block.buttonText || block.content}</span>
            <svg class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>
      );
    
    case 'status':
      const statusClass = `status-badge status-${block.status || 'coming-soon'}`;
      return (
        <div class="my-4">
          <span class={statusClass}>
            {block.status === 'coming-soon' && '⏳ '}
            {block.status === 'available' && '✅ '}
            {block.status === 'closed' && '❌ '}
            {block.content}
          </span>
        </div>
      );
    
    case 'collapsible':
      if (typeof block.content === 'object' && 'title' in block.content) {
        const collapsibleContent = block.content as CollapsibleContent;
        return <CollapsibleContentComponent content={collapsibleContent} group={collapsibleGroup} />;
      }
      return null;
    
    case 'table':
      if (typeof block.content === 'object' && 'headers' in block.content) {
        const { headers, rows, alignments } = block.content;
        const alignClass = (a: string) =>
          a === 'right' ? 'text-right' : a === 'center' ? 'text-center' : 'text-left';
        return (
          <div class="overflow-x-auto my-8 inline-block max-w-full rounded-xl shadow-sm border border-primary-200 dark:border-primary-700">
            <table class="w-auto divide-y divide-primary-200 dark:divide-primary-700">
              <thead>
                <tr class="bg-gradient-to-r from-primary-700 to-primary-800 dark:from-primary-800 dark:to-primary-900">
                  {headers.map((h: string, ci: number) => (
                    <th
                      scope="col"
                      class={`px-6 py-4 text-base font-semibold text-white tracking-wide ${alignClass(alignments[ci] ?? 'none')} first:rounded-tl-xl last:rounded-tr-xl`}
                      set:html={h}
                    />
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-primary-100 dark:divide-primary-700 bg-white dark:bg-primary-800">
                {rows.map((row: string[], ri: number) => (
                  <tr class={ri % 2 === 0 ? 'bg-white dark:bg-primary-800' : 'bg-primary-50 dark:bg-primary-800/60'}>
                    {row.map((cell: string, ci: number) => (
                      <td class={`px-6 py-4 text-base text-primary-800 dark:text-primary-200 ${alignClass(alignments[ci] ?? 'none')} ${ci === 0 ? 'font-medium text-primary-900 dark:text-primary-100' : ''}`}>
                        {cell}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        );
      }
      return null;

    case 'pdfpreview':
      return (
        <div class="my-8">
          <a
            href={block.url}
            download
            class="group block max-w-md mx-auto rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-shadow duration-300 border border-primary-200 dark:border-primary-700 focus:outline-none focus:ring-2 focus:ring-accent-500"
            title={block.title || 'Download PDF'}
            aria-label={block.title || 'Download PDF'}
          >
            <div class="relative">
              <img
                src={block.preview}
                alt={`Preview of ${block.title || 'PDF document'}`}
                class="w-full object-cover"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/30 transition-colors duration-300 flex items-center justify-center">
                <div class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-white dark:bg-primary-800 rounded-full px-5 py-3 flex items-center gap-2 shadow-lg">
                  <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                  </svg>
                  <span class="text-sm font-semibold text-primary-900 dark:text-primary-100">Download PDF</span>
                </div>
              </div>
            </div>
            <div class="bg-primary-50 dark:bg-primary-800 px-4 py-3 flex items-center gap-2">
              <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zm-1 1.5L18.5 9H13V3.5zM6 20V4h5v7h7v9H6z"/>
              </svg>
              <span class="text-sm font-medium text-primary-700 dark:text-primary-200 truncate">{block.title || 'Download PDF'}</span>
              <svg class="w-4 h-4 text-primary-400 ml-auto flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
              </svg>
            </div>
          </a>
        </div>
      );
    
    case 'video': {
      const videoId = `video-${Math.random().toString(36).slice(2, 9)}`;
      return (
        <div class="my-6 rounded-xl overflow-hidden shadow-md" id={videoId}>
          <div class="relative w-full" style="padding-top: 56.25%;">
            {/* Click-to-play overlay */}
            <div
              class="video-overlay absolute inset-0 w-full h-full flex flex-col items-center justify-center cursor-pointer rounded-xl z-10 bg-gradient-to-br from-primary-900 via-primary-800 to-primary-900"
              style={block.bg ? `background-image: url('${block.bg}'); background-size: cover; background-position: center;` : ''}
              onclick={`
                var el = document.getElementById('${videoId}');
                el.querySelector('.video-overlay').style.display = 'none';
                el.querySelector('iframe').style.display = 'block';
              `}
            >
              {/* Dark scrim over background image for readability */}
              {block.bg && <div class="absolute inset-0 bg-black/50 rounded-xl"></div>}
              {/* Play button */}
              <div class="relative z-10 w-20 h-20 rounded-full bg-white/20 hover:bg-white/30 transition-colors duration-200 flex items-center justify-center mb-5 backdrop-blur-sm border border-white/30">
                <svg class="w-9 h-9 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
              {block.title && (
                <p class="relative z-10 text-white text-xl font-semibold tracking-wide text-center px-6">{block.title}</p>
              )}
              <p class="relative z-10 text-white/60 text-sm mt-2">Click to play</p>
            </div>
            {/* Iframe — hidden until overlay is clicked */}
            <iframe
              src={block.src}
              allow="autoplay"
              allowfullscreen
              class="absolute inset-0 w-full h-full border-0 rounded-xl"
              style="display: none;"
              title={block.title || 'Video'}
            ></iframe>
          </div>
        </div>
      );
    }

    case 'floorplan':
      return (
        <div class="my-6">
          <ExhibitorFloorPlan />
        </div>
      );

    default:
      return null;
  }
})}