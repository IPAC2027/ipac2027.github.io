---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getEntry } from 'astro:content';
import { exhibitors, getExhibitorsByTier } from '../../data/exhibitors';

const entry = await getEntry('exhibitors', 'exhibitor_list');
if (!entry) {
  throw new Error('Page content not found');
}

const sortByDescription = (list: typeof exhibitors) =>
  [...list].sort((a, b) => (b.description ? 1 : 0) - (a.description ? 1 : 0));

const diamondExhibitors = sortByDescription(getExhibitorsByTier('diamond'));
const platinumExhibitors = sortByDescription(getExhibitorsByTier('platinum'));
const goldExhibitors = sortByDescription(getExhibitorsByTier('gold'));

const tierConfig = [
  { label: 'Diamond', exhibitors: diamondExhibitors, logoClass: 'h-24 md:h-32', gridClass: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3', cardPad: 'p-10', dot: 'bg-cyan-400' },
  { label: 'Platinum', exhibitors: platinumExhibitors, logoClass: 'h-20 md:h-24', gridClass: 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4', cardPad: 'p-8', dot: 'bg-gray-300' },
  { label: 'Gold', exhibitors: goldExhibitors, logoClass: 'h-16 md:h-20', gridClass: 'grid-cols-2 md:grid-cols-4 lg:grid-cols-5', cardPad: 'p-6', dot: 'bg-yellow-400' },
];
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  bannerText={entry.data.bannerText || "IPAC'27 Exhibitors"}
  bannerBackground={entry.data.bannerBackground}
  headings={[]}
>
  <div class="py-4">
    <p class="text-lg text-primary-600 dark:text-primary-300 mb-12">
      Meet the companies and organizations exhibiting at IPAC'27 in Detroit, Michigan.
    </p>

    {tierConfig.map(({ label, exhibitors: tierExhibitors, logoClass, gridClass, cardPad, dot }) =>
      tierExhibitors.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-semibold text-primary-900 dark:text-primary-100 mb-8 flex items-center">
            <span class={`inline-block w-3 h-3 rounded-full ${dot} mr-3`}></span>
            {label} Exhibitors
          </h2>
          <div class={`grid ${gridClass} gap-6`}>
            {tierExhibitors.map((exhibitor) => (
              <a
                href={exhibitor.website || '#'}
                target={exhibitor.website && exhibitor.website !== '#' ? '_blank' : undefined}
                rel={exhibitor.website && exhibitor.website !== '#' ? 'noopener noreferrer' : undefined}
                class={`bg-white dark:bg-primary-800 rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 flex flex-col items-center justify-center ${cardPad}`}
              >
                <img
                  src={exhibitor.logo}
                  alt={`${exhibitor.name} logo`}
                  class={`${logoClass} w-auto object-contain`}
                />
                <p class="mt-4 text-sm font-medium text-primary-700 dark:text-primary-200 text-center">{exhibitor.name}</p>
                {exhibitor.booth && (
                  <span class="mt-1 text-xs text-primary-500 dark:text-primary-400">Booth {exhibitor.booth}</span>
                )}
                {exhibitor.description && (
                  <span class="mt-1 text-xs font-semibold text-accent-600 dark:text-accent-400 text-center">{exhibitor.description}</span>
                )}
              </a>
            ))}
          </div>
        </section>
      )
    )}

    {exhibitors.length === 0 && (
      <p class="text-primary-500 dark:text-primary-400 italic">Exhibitor information will be announced soon.</p>
    )}
  </div>
</ContentLayout>
